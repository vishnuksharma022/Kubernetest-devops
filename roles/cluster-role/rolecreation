########### Cluser Scope Role-Binding Creation ####################################

User Level

kubectl create clusterrolebinding  test --clusterrole=admin --user=user1
kubectl describe  clusterrolebinding demo

Group Level
kubectl create clusterrolebinding demo --clusterrole=cluster-admin --group=developers
kubectl describe  clusterrolebinding demo


###########  namespace Scope Role-Binding #################################


kubectl create rolebinding  test --clusterrole=admin --user=user1 -n kube-system
kubectl get rolebinding -n kube-system


Group Level
kubectl create rolebinding demo --clusterrole=cluster-admin --group=developers -n kube-system
kubectl get rolebinding -n kube-system


####### Custome Role Creation and Bainding with user ##########################

Cluster Level 

kubectl create clusterrole pod-view --resource=pod --verb=list,get,describe
kubectl get clusterrole pod-view 
kubectl describe clusterrole pod-view 
kubectl create clusterrolebinding pod-view --user=user1 --clusterrole=pod-view
kubectl get  clusterrolebinding pod-view 


 NameSpace Level
kubectl create clusterrole pod-view --resource=pod --verb=list,get,describe
kubectl create rolebinding demo --clusterrole=pod-view  --user=user1 -n kube-system
kubectl create rolebinding demo --clusterrole=pod-view  --group=developers -n kube-system