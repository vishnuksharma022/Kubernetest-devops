Step 1 — Jump Host par Private Key generate
Run on Jump Host
openssl genrsa -out ram.key 2048

Step 2 — CSR generate
Run on Jump Host
openssl req -new -key ram.key -out ram.csr -subj "/CN=ram/O=developers"

CN = username
O = group name

Step 3 — CSR ko base64 encode karo
cat ram.csr | base64 | tr -d '\n'


Step 4 — CSR YAML banao
Run on Master Node

apiVersion: certificates.k8s.io/v1
kind: CertificateSigningRequest
metadata:
  name: ram-csr
spec:
  request: PASTE_BASE64_CSR_HERE
  signerName: kubernetes.io/kube-apiserver-client
  expirationSeconds: 86400
  usages:
  - client auth

  # kubectl apply -f ram-csr.yaml

Step 5 — CSR approve karo
Run on Master Node

kubectl certificate approve ram-csr

kubectl get csr

Step 6 — Certificate download karo
Run on Master Node

kubectl get csr ram-csr -o jsonpath='{.status.certificate}' | base64 -d > ram.crt

crt & CA ko jump host par copy karo.
scp ram.crt ram@jump-host:/home/ram/
scp  /etc/kubernetes/pki/ca.crt   shyam@192.168.153.157:/home/shyam/

Step 7 — Cluster configuration
Run on Jump Host

kubectl config set-cluster kubernetes \
--server=https://192.168.153.155:6443 \
--certificate-authority=ca.crt \
--embed-certs=true

Step 8 — User credentials add karo
Run on Jump Host

kubectl config set-credentials ram \
--client-certificate=ram.crt \
--client-key=ram.key \
--embed-certs=true

Step 9 — Context create karo

kubectl config set-context ram-context \
--cluster=kubernetes \
--user=ram \
--namespace=default

Step 10 — Context activate karo
kubectl config use-context ram-context